        { "action": "spirit_attack", "weight": 20, "name": "Veil of Fear", "power_mult": 0.6, "uses": "spr", "status": "fear", "status_chance": 0.45, "counter_virtue": "fortitude", "counter_level": 3, "dialogue": "The soldiers are coming. You can hear their boots. Run." },
        { "action": "spirit_attack", "weight": 20, "name": "Honeyed Lie", "power_mult": 0.5, "uses": "spr", "status": "confusion", "status_chance": 0.4, "counter_virtue": "prudence", "counter_level": 3, "dialogue": "Step on the image. It is only wood. God will understand." },
        { "action": "drain", "weight": 15, "name": "Consume Faith", "drain_mp": 8, "dialogue": "Your prayers grow quieter. Have you noticed?" },
